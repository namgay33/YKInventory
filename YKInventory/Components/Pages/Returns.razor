@page "/returns"
@rendermode InteractiveServer
@using YKInventory.Models
@using System.Text.Json
@using System.Net.Http.Json
@inject HttpClient Http

<h2>🔄 Return Asset</h2>
<hr />

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <div class="mb-3">
                    <label>Select Issued Asset to Return</label>
                    <select class="form-control" @bind="selectedTransactionId">
                        <option value="0">-- Select Asset to Return --</option>
                        @foreach (var t in issuedTransactions)
                        {
                            <option value="@t.Id">@t.AssetTag - @t.AssetName (Issued to: @t.EmployeeName on @t.Date)</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label>Condition on Return</label>
                    <select class="form-control" @bind="conditionOnReturn">
                        <option value="Good">Good</option>
                        <option value="Minor Damage">Minor Damage</option>
                        <option value="Major Damage">Major Damage</option>
                        <option value="Under Repair">Under Repair</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label>Return Remarks</label>
                    <textarea class="form-control" rows="3" placeholder="Any issues or notes about the asset..." @bind="returnRemarks"></textarea>
                </div>
                <button class="btn btn-warning" @onclick="ReturnAsset">Confirm Return</button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <div class='alert alert-info mt-3'>@message</div>
}

@code {
    private List<TransactionViewModel> issuedTransactions = new();
    private int selectedTransactionId = 0;
    private string conditionOnReturn = "Good";
    private string returnRemarks = "";
    private string message = "";
    private string apiBase = "http://localhost:5168";

    public class TransactionViewModel
    {
        public int Id { get; set; }
        public string Date { get; set; } = "";
        public string AssetTag { get; set; } = "";
        public string AssetName { get; set; } = "";
        public string EmployeeName { get; set; } = "";
        public string Department { get; set; } = "";
        public int Quantity { get; set; }
        public string Status { get; set; } = "";
        public string Remarks { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadIssuedAssets();
    }

    private async Task LoadIssuedAssets()
    {
        try
        {
            var allTransactions = await Http.GetFromJsonAsync<List<TransactionViewModel>>($"{apiBase}/api/transactions");
            issuedTransactions = allTransactions?.Where(t => t.Status == "Issued").ToList() ?? new();
            message = $"Found {issuedTransactions.Count} issued assets";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
        StateHasChanged();
    }

    private async Task ReturnAsset()
    {
        if (selectedTransactionId == 0)
        {
            message = "Please select an asset to return";
            return;
        }

        try
        {
            var request = new
            {
                transactionId = selectedTransactionId,
                condition = conditionOnReturn,
                remarks = returnRemarks
            };

            var response = await Http.PostAsJsonAsync($"{apiBase}/api/return", request);
            if (response.IsSuccessStatusCode)
            {
                message = "✓ Asset returned successfully!";
                await LoadIssuedAssets();
                selectedTransactionId = 0;
                conditionOnReturn = "Good";
                returnRemarks = "";
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                message = $"Error: {error}";
            }
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
        StateHasChanged();
    }
}