@page "/transactions"
@rendermode InteractiveServer
@using YKInventory.Models
@using System.Net.Http.Json
@inject HttpClient Http

<h2>📜 Transaction History</h2>
<hr />
<p>📋 Complete history of all asset checkouts and returns</p>

<div class="table-toolbar">
    <div class="search-box ms-auto">
        <input class="form-control" placeholder="🔍 Search transactions..." @bind="transactionSearch" @bind:event="oninput" />
    </div>
</div>

<div class="table-responsive inventory-table-wrap">
    <table class='table table-striped table-bordered align-middle inventory-table'>
        <thead class='table-dark'>
            <tr>
                <th>📅 Date</th>
                <th>🏷️ Asset Tag</th>
                <th>📦 Asset Name</th>
                <th>👤 Employee</th>
                <th>🏢 Department</th>
                <th>🔢 Quantity</th>
                <th>📊 Status</th>
                <th>🔄 Returned On</th>
                <th>🔧 Condition</th>
                <th>📝 Remarks</th>
            </tr>
        </thead>
        <tbody>
            @if (!FilteredTransactions.Any())
            {
                <tr>
                    <td colspan="10" class="text-center"> <span>📭 No transactions found. Check out an asset first. </span></td>
                </tr>
            }
            else
            {
                @foreach (var t in FilteredTransactions)
                {
                    <tr>
                        <td><span>@t.Date</span></td>
                        <td><span>@t.AssetTag</span></td>
                        <td><span>@t.AssetName</span></td>
                        <td><span>@t.EmployeeName</span></td>
                        <td><span>@t.Department</span></td>
                        <td><span>@t.Quantity</span></td>
                        <td><span class='badge @(t.Status == "Issued" ? "bg-warning" : "bg-success")'>@t.Status</span></td>
                        <td><span>@(string.IsNullOrEmpty(t.ReturnedDate) ? "⏳ Not returned" : t.ReturnedDate)</span></td>
                        <td><span>@(string.IsNullOrEmpty(t.Condition) ? "✅ N/A" : t.Condition)</span></td>
                        <td><span>@(string.IsNullOrEmpty(t.Remarks) ? "—" : t.Remarks)</span></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    private List<TransactionViewModel> transactions = new();
    private string apiBase = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Production" 
        ? "http://172.30.30.17:8080" 
        : "http://localhost:5168";
    private string transactionSearch = "";

    private IEnumerable<TransactionViewModel> FilteredTransactions =>
        string.IsNullOrWhiteSpace(transactionSearch)
            ? transactions
            : transactions.Where(t => SearchMatches(
                transactionSearch,
                t.Date,
                t.AssetTag,
                t.AssetName,
                t.EmployeeName,
                t.Department,
                t.Quantity.ToString(),
                t.Status,
                t.ReturnedDate,
                t.Condition,
                t.Remarks));

    private static bool SearchMatches(string search, params string?[] values) =>
        values.Any(value => !string.IsNullOrWhiteSpace(value) &&
                            value.Contains(search, StringComparison.OrdinalIgnoreCase));

    public class TransactionViewModel
    {
        public int Id { get; set; }
        public string Date { get; set; } = "";
        public string AssetTag { get; set; } = "";
        public string AssetName { get; set; } = "";
        public string EmployeeName { get; set; } = "";
        public string Department { get; set; } = "";
        public int Quantity { get; set; }
        public string Status { get; set; } = "";
        public string ReturnedDate { get; set; } = "";
        public string Condition { get; set; } = "";
        public string Remarks { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        try
        {
            transactions = await Http.GetFromJsonAsync<List<TransactionViewModel>>($"{apiBase}/api/transactions") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error: {ex.Message}");
        }
        StateHasChanged();
    }
}