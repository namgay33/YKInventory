@page "/returns"
@rendermode InteractiveServer
@using YKInventory.Models
@using System.Text.Json
@using System.Net.Http.Json
@inject HttpClient Http

<style>
    .returns-container {
        background-image: url('/images/background.png');
        background-size: contain;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
        min-height: 100vh;
        padding: 20px;
        position: relative;
        width: 100%;
        box-sizing: border-box;
    }

    .returns-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(255, 255, 255, 0.88);
        z-index: 0;
    }

    .returns-container > div {
        position: relative;
        z-index: 1;
    }

    .form-card {
        max-width: 600px;
        margin: 0 auto;
    }

    @@media (max-width: 768px) {
        .returns-container {
            padding: 15px;
        }
        
        h2 {
            font-size: 1.5rem;
        }
    }
</style>

<div class="returns-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2> Return Asset</h2>
    </div>
    <hr />

    <div class="form-card card shadow-sm">
        <div class="card-body p-4">
            <div class="mb-3">
                <label class="fw-bold">📋 Select Issued Asset to Return <span class="text-danger">*</span></label>
                <select class="form-control" @bind="selectedTransactionId">
                    <option value="0">-- Select Asset to Return --</option>
                    @foreach (var t in issuedTransactions)
                    {
                        <option value="@t.Id">📦 @t.AssetTag - @t.AssetName (👤 @t.EmployeeName on 📅 @t.Date)</option>
                    }
                </select>
                <small class="text-muted">Choose an asset currently issued to return it</small>
            </div>

            <div class="mb-3">
                <label class="fw-bold"> Condition on Return</label>
                <select class="form-control" @bind="conditionOnReturn">
                    <option value="Good">✅ Good</option>
                    <option value="Minor Damage">️ Minor Damage</option>
                    <option value="Major Damage">❌ Major Damage</option>
                    <option value="Under Repair">🔧 Under Repair</option>
                </select>
                <small class="text-muted">Current physical state of the asset</small>
            </div>

            <div class="mb-3">
                <label class="fw-bold">📝 Return Remarks</label>
                <textarea class="form-control" rows="3" placeholder="Any issues or notes about the asset..." @bind="returnRemarks"></textarea>
                <small class="text-muted">Optional details about the return condition</small>
            </div>

            <button class="btn btn-warning w-100" @onclick="ReturnAsset">🔄 Confirm Return</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class='alert alert-info mt-3'>@message</div>
    }
</div>

@code {
    private List<TransactionViewModel> issuedTransactions = new();
    private int selectedTransactionId = 0;
    private string conditionOnReturn = "Good";
    private string returnRemarks = "";
    private string message = "";
    private string apiBase = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Production" 
        ? "http://172.30.30.17:8080" 
        : "http://localhost:5168";

    public class TransactionViewModel
    {
        public int Id { get; set; }
        public string Date { get; set; } = "";
        public string AssetTag { get; set; } = "";
        public string AssetName { get; set; } = "";
        public string EmployeeName { get; set; } = "";
        public string Department { get; set; } = "";
        public int Quantity { get; set; }
        public string Status { get; set; } = "";
        public string Remarks { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadIssuedAssets();
    }

    private async Task LoadIssuedAssets()
    {
        try
        {
            var allTransactions = await Http.GetFromJsonAsync<List<TransactionViewModel>>($"{apiBase}/api/transactions");
            issuedTransactions = allTransactions?.Where(t => t.Status == "Issued").ToList() ?? new();
            message = $"📋 Found {issuedTransactions.Count} issued assets";
        }
        catch (Exception ex)
        {
            message = $"❌ Error: {ex.Message}";
        }
        StateHasChanged();
    }

    private async Task ReturnAsset()
    {
        if (selectedTransactionId == 0)
        {
            message = "⚠️ Please select an asset to return";
            return;
        }

        try
        {
            var request = new
            {
                transactionId = selectedTransactionId,
                condition = conditionOnReturn,
                remarks = returnRemarks
            };

            var response = await Http.PostAsJsonAsync($"{apiBase}/api/return", request);
            if (response.IsSuccessStatusCode)
            {
                message = "✅ Asset returned successfully!";
                await LoadIssuedAssets();
                selectedTransactionId = 0;
                conditionOnReturn = "Good";
                returnRemarks = "";
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                message = $"❌ Error: {error}";
            }
        }
        catch (Exception ex)
        {
            message = $"❌ Error: {ex.Message}";
        }
        StateHasChanged();
    }
}