@page "/"
@rendermode InteractiveServer
@using YKInventory.Models
@using System.Net.Http.Json
@inject HttpClient Http

<div class="container-fluid">
    <h2 class="mb-4">📊 YK Inventory Dashboard</h2>
    
    <div class="row">
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <h5 class="card-title">Total Assets</h5>
                    <h2 class="card-text">@totalAssets</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <h5 class="card-title">Available Assets</h5>
                    <h2 class="card-text">@availableAssets</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <h5 class="card-title">Currently Issued</h5>
                    <h2 class="card-text">@issuedAssets</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <h5 class="card-title">Total Employees</h5>
                    <h2 class="card-text">@totalEmployees</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5>📋 Recent Transactions</h5>
                </div>
                <div class="card-body">
                    <div class="search-box mb-3">
                        <input class="form-control form-control-sm" placeholder="Search transactions..." @bind="recentTransactionSearch" @bind:event="oninput" />
                    </div>
                    <div class="table-responsive">
                        <table class='table table-sm'>
                            <thead>
                                <tr><th>Date</th><th>Asset</th><th>Employee</th><th>Status</th></tr>
                            </thead>
                            <tbody>
                                @if (!FilteredRecentTransactions.Any())
                                {
                                    <tr><td colspan='4' class='text-center'>No transactions found.</td></tr>
                                }
                                else
                                {
                                    @foreach (var t in FilteredRecentTransactions)
                                    {
                                        <tr>
                                            <td>@t.Date</td>
                                            <td>@t.AssetName</td>
                                            <td>@t.EmployeeName</td>
                                            <td><span class='badge @(t.Status == "Issued" ? "bg-warning" : "bg-success")'>@t.Status</span></td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5>⚠️ Expiring Warranty (Next 3 months)</h5>
                </div>
                <div class="card-body">
                    <div class="search-box mb-3">
                        <input class="form-control form-control-sm" placeholder="Search warranties..." @bind="warrantySearch" @bind:event="oninput" />
                    </div>
                    <div class="table-responsive">
                        <table class='table table-sm'>
                            <thead>
                                <tr><th>Asset</th><th>Warranty Expiry</th></tr>
                            </thead>
                            <tbody>
                                @if (!FilteredExpiringWarranty.Any())
                                {
                                    <tr><td colspan='2' class='text-center'>No warranties found.</td></tr>
                                }
                                else
                                {
                                    @foreach (var a in FilteredExpiringWarranty)
                                    {
                                        <tr>
                                            <td>@a.Name</td>
                                            <td>@a.WarrantyExpiry?.ToString("yyyy-MM-dd")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int totalAssets = 0, availableAssets = 0, issuedAssets = 0, totalEmployees = 0;
    private List<TransactionDto> recentTransactions = new();
    private List<Asset> expiringWarranty = new();
    @* private string apiBase = "http://localhost:5168"; *@

    private string apiBase = "";
    
    private string recentTransactionSearch = "";
    private string warrantySearch = "";

    private IEnumerable<TransactionDto> FilteredRecentTransactions =>
        string.IsNullOrWhiteSpace(recentTransactionSearch)
            ? recentTransactions
            : recentTransactions.Where(t => SearchMatches(
                recentTransactionSearch,
                t.Date,
                t.AssetName,
                t.EmployeeName,
                t.Status));

    private IEnumerable<Asset> FilteredExpiringWarranty =>
        string.IsNullOrWhiteSpace(warrantySearch)
            ? expiringWarranty
            : expiringWarranty.Where(a => SearchMatches(
                warrantySearch,
                a.Name,
                a.WarrantyExpiry?.ToString("yyyy-MM-dd")));

    private static bool SearchMatches(string search, params string?[] values) =>
        values.Any(value => !string.IsNullOrWhiteSpace(value) &&
                            value.Contains(search, StringComparison.OrdinalIgnoreCase));

    public class TransactionDto
    {
        public string Date { get; set; } = "";
        public string AssetName { get; set; } = "";
        public string EmployeeName { get; set; } = "";
        public string Status { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        try
        {
            var assets = await Http.GetFromJsonAsync<List<Asset>>($"{apiBase}/api/assets");
            if (assets != null)
            {
                totalAssets = assets.Count;
                availableAssets = assets.Count(a => a.Status == "Available");
                issuedAssets = assets.Count(a => a.Status == "Issued");
                expiringWarranty = assets.Where(a => a.WarrantyExpiry.HasValue && a.WarrantyExpiry.Value < DateTime.Now.AddMonths(3)).Take(5).ToList();
            }

            var employees = await Http.GetFromJsonAsync<List<Employee>>($"{apiBase}/api/employees");
            totalEmployees = employees?.Count ?? 0;

            var transactions = await Http.GetFromJsonAsync<List<TransactionDto>>($"{apiBase}/api/transactions");
            recentTransactions = transactions?.Take(10).ToList() ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard: {ex.Message}");
        }
        StateHasChanged();
    }
}
