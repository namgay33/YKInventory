@page "/transactions"
@rendermode InteractiveServer
@using YKInventory.Models
@using System.Net.Http.Json
@inject HttpClient Http

<style>
    .transactions-container {
        background-image: url('/images/background.png');
        background-size: contain;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
        min-height: 100vh;
        padding: 20px;
        position: relative;
        width: 100%;
        box-sizing: border-box;
    }

    .transactions-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(255, 255, 255, 0.88);
        z-index: 0;
    }

    .transactions-container > div {
        position: relative;
        z-index: 1;
    }

    .inventory-table-wrap {
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        background: white;
    }

    .inventory-table {
        width: 100%;
        margin-bottom: 0;
        border-collapse: collapse;
        table-layout: auto;
    }

    .inventory-table th,
    .inventory-table td {
        vertical-align: middle;
        padding: 0.75rem;
        border: 1px solid #dee2e6;
        word-break: break-word;
        white-space: normal;
    }

    .inventory-table thead th {
        white-space: nowrap;
        background-color: #212529;
        color: white;
    }

    .table-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .75rem;
        margin-bottom: 1rem;
    }

    .search-box {
        width: min(100%, 360px);
        margin-left: auto;
    }

    @@media (max-width: 768px) {
        .d-flex.justify-content-between.align-items-center.mb-3 {
            align-items: flex-start !important;
            flex-direction: column;
            gap: .75rem;
        }

        .table-toolbar {
            align-items: stretch;
            flex-direction: column;
        }

        .search-box {
            width: 100%;
            margin-left: 0;
        }
    }
</style>

<div class="transactions-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📜 Transaction History</h2>
    </div>
    <p class="text-muted"> Complete history of all asset checkouts and returns</p>
    <hr />

    <div class="table-toolbar">
        <div class="search-box">
            <input class="form-control" placeholder="🔍 Search transactions..." @bind="transactionSearch" @bind:event="oninput" />
        </div>
    </div>

    <div class="inventory-table-wrap shadow-sm">
        <table class='table table-striped table-bordered align-middle inventory-table mb-0'>
            <thead class='table-dark'>
                <tr>
                    <th>Date</th>
                    <th>Asset Tag</th>
                    <th>Asset Name</th>
                    <th>Employee</th>
                    <th>Department</th>
                    <th>Qty</th>
                    <th>Status</th>
                    <th>Returned On</th>
                    <th>Condition</th>
                    <th>Remarks</th>
                </tr>
            </thead>
            <tbody>
                @if (!FilteredTransactions.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center">No transactions found. Check out an asset first.</td>
                    </tr>
                }
                else
                {
                    @foreach (var t in FilteredTransactions)
                    {
                        <tr>
                            <td>@t.Date</td>
                            <td>@t.AssetTag</td>
                            <td>@t.AssetName</td>
                            <td>@t.EmployeeName</td>
                            <td>@t.Department</td>
                            <td>@t.Quantity</td>
                            <td><span class='badge @(t.Status == "Issued" ? "bg-warning" : "bg-success")'>@t.Status</span></td>
                            <td>@(string.IsNullOrEmpty(t.ReturnedDate) ? "⏳ Not returned" : t.ReturnedDate)</td>
                            <td>@(string.IsNullOrEmpty(t.Condition) ? "✅ N/A" : t.Condition)</td>
                            <td>@(string.IsNullOrEmpty(t.Remarks) ? "—" : t.Remarks)</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<TransactionViewModel> transactions = new();
    private string apiBase = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Production" 
        ? "http://172.30.30.17:8080" 
        : "http://localhost:5168";
    private string transactionSearch = "";

    private IEnumerable<TransactionViewModel> FilteredTransactions =>
        string.IsNullOrWhiteSpace(transactionSearch)
            ? transactions
            : transactions.Where(t => SearchMatches(
                transactionSearch,
                t.Date,
                t.AssetTag,
                t.AssetName,
                t.EmployeeName,
                t.Department,
                t.Quantity.ToString(),
                t.Status,
                t.ReturnedDate,
                t.Condition,
                t.Remarks));

    private static bool SearchMatches(string search, params string?[] values) =>
        values.Any(value => !string.IsNullOrWhiteSpace(value) &&
                            value.Contains(search, StringComparison.OrdinalIgnoreCase));

    public class TransactionViewModel
    {
        public int Id { get; set; }
        public string Date { get; set; } = "";
        public string AssetTag { get; set; } = "";
        public string AssetName { get; set; } = "";
        public string EmployeeName { get; set; } = "";
        public string Department { get; set; } = "";
        public int Quantity { get; set; }
        public string Status { get; set; } = "";
        public string ReturnedDate { get; set; } = "";
        public string Condition { get; set; } = "";
        public string Remarks { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        try
        {
            transactions = await Http.GetFromJsonAsync<List<TransactionViewModel>>($"{apiBase}/api/transactions") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error: {ex.Message}");
        }
        StateHasChanged();
    }
}