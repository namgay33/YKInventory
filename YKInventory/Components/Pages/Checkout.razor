@page "/checkout"
@rendermode InteractiveServer
@using YKInventory.Models
@using System.Net.Http.Json
@inject HttpClient Http

<style>
    .checkout-container {
        background-image: url('/images/background.png');
        background-size: contain;
        background-position: center;
        background-attachment: fixed;
        background-repeat: no-repeat;
        min-height: 100vh;
        padding: 20px;
        position: relative;
        width: 100%;
        box-sizing: border-box;
    }

    .checkout-container::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(255, 255, 255, 0.88);
        z-index: 0;
    }

    .checkout-container > div {
        position: relative;
        z-index: 1;
    }

    .form-card {
        max-width: 600px;
        margin: 0 auto;
    }

    @@media (max-width: 768px) {
        .checkout-container {
            padding: 15px;
        }
        
        h2 {
            font-size: 1.5rem;
        }
    }
</style>

<div class="checkout-container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>✅ Check Out Asset</h2>
    </div>
    <hr />

    <div class="form-card card shadow-sm">
        <div class="card-body p-4">
            <div class="mb-3">
                <label class="fw-bold">Select Asset <span class="text-danger">*</span></label>
                <select class="form-control" @bind="selectedAssetId">
                    <option value="0">-- Select Asset --</option>
                    @foreach (var a in availableAssets)
                    {
                        <option value="@a.Id">📦 @a.AssetTag - @a.Name (@a.Category)</option>
                    }
                </select>
                <small class="text-muted">Choose an available asset to check out</small>
            </div>

            <div class="mb-3">
                <label class="fw-bold">Select Employee <span class="text-danger">*</span></label>
                <select class="form-control" @bind="selectedEmployeeId">
                    <option value="0">-- Select Employee --</option>
                    @foreach (var e in employees)
                    {
                        <option value="@e.Id">👤 @e.EmployeeCode - @e.FullName (@e.Department)</option>
                    }
                </select>
                <small class="text-muted">Assign asset to this employee</small>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Quantity</label>
                    <input type="number" class="form-control" min="1" @bind="quantity" />
                    <small class="text-muted">Number of units</small>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="fw-bold">Expected Return Date</label>
                    <input type="date" class="form-control" @bind="expectedReturnDate" />
                    <small class="text-muted">When should it be returned?</small>
                </div>
            </div>

            <div class="mb-3">
                <label class="fw-bold">Remarks</label>
                <textarea class="form-control" rows="3" placeholder="Purpose of taking this asset..." @bind="remarks"></textarea>
                <small class="text-muted">Optional notes or purpose</small>
            </div>

            <button class="btn btn-success w-100" @onclick="CheckoutAsset">✅ Confirm Checkout</button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class='alert alert-info mt-3'>@message</div>
    }
</div>

@code {
    private List<Asset> availableAssets = new();
    private List<Employee> employees = new();
    private int selectedAssetId = 0, selectedEmployeeId = 0, quantity = 1;
    private DateTime expectedReturnDate = DateTime.Now.AddMonths(3);
    private string remarks = "";
    private string message = "";
    private string apiBase = Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Production" 
        ? "http://172.30.30.17:8080" 
        : "http://localhost:5168";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            availableAssets = await Http.GetFromJsonAsync<List<Asset>>($"{apiBase}/api/assets/available") ?? new();
            employees = await Http.GetFromJsonAsync<List<Employee>>($"{apiBase}/api/employees") ?? new();
        }
        catch (Exception ex)
        {
            message = $"✗ Error: {ex.Message}";
        }
        StateHasChanged();
    }

    private async Task CheckoutAsset()
    {
        if (selectedAssetId == 0 || selectedEmployeeId == 0)
        {
            message = "⚠️ Please select both asset and employee";
            return;
        }

        try
        {
            var request = new
            {
                assetId = selectedAssetId,
                employeeId = selectedEmployeeId,
                quantity = quantity,
                expectedReturnDate = expectedReturnDate,
                remarks = remarks
            };

            var response = await Http.PostAsJsonAsync($"{apiBase}/api/checkout", request);
            if (response.IsSuccessStatusCode)
            {
                message = "✅ Asset checked out successfully!";
                await LoadData();
                selectedAssetId = 0;
                selectedEmployeeId = 0;
                quantity = 1;
                expectedReturnDate = DateTime.Now.AddMonths(3);
                remarks = "";
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                message = $"✗ Error: {error}";
            }
        }
        catch (Exception ex)
        {
            message = $"✗ Error: {ex.Message}";
        }
        StateHasChanged();
    }
}